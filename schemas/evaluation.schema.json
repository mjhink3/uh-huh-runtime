{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://uh-huh.local/schemas/evaluation.schema.json",
  "title": "Uh-Huh Runtime V0.1 Evaluation",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "decision",
    "detected_gap",
    "missing_evidence",
    "question_asked",
    "resolution_status",
    "resolution_evidence",
    "final_decision",
    "rationale"
  ],
  "properties": {
    "decision": { "type": "string", "enum": ["allow", "ask", "confirm", "escalate"] },
    "detected_gap": { "type": ["string", "null"] },
    "missing_evidence": { "type": "array", "items": { "type": "string" } },
    "question_asked": { "type": ["string", "null"] },
    "resolution_status": {
      "type": "string",
      "enum": ["not_applicable", "unresolved", "resolved", "escalated"]
    },
    "resolution_evidence": { "type": "array", "items": { "type": "string" } },
    "final_decision": { "type": "string", "enum": ["allow", "ask", "confirm", "escalate"] },
    "rationale": { "type": "string" }
  }
}
